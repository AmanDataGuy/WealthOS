# WealthOS — Environment Variables Reference
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.
#
# Required keys are marked [REQUIRED]. Everything else has a working default.

# ── Database ──────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL + pgvector connection string.
# Used by: all 7 agents, finance/portfolio MCP servers, RAG indexer, rebalancing agent.
# docker-compose default: postgresql://wealthos:wealthos_secure_password@localhost:5432/wealthos
WEALTHOS_DB_URL=postgresql://wealthos:wealthos_secure_password@localhost:5432/wealthos

# ── Cache ─────────────────────────────────────────────────────────────────────

# Redis connection string.
# Used by: api/main.py (analysis cache), data_agent.py, market/news/sec_edgar MCP servers.
# Default connects to local Redis on the standard port.
REDIS_URL=redis://localhost:6379

# ── LLM Providers ─────────────────────────────────────────────────────────────

# [REQUIRED] Groq API key — primary LLM provider (llama-3.3-70b-versatile).
# Used by: risk_agent, writer_agent, code_agent, llm_client (primary in fallback chain),
#          eval/evaluate.py (LLM-as-judge), weave_config.py (memo scorer).
# Get key: https://console.groq.com
GROQ_API_KEY=gsk_...

# Ollama base URL — local LLM server for offline / fallback inference.
# Used by: llm_client.py (Groq→Ollama fallback), data_agent.py, research_agent.py,
#          rag/indexer.py (mxbai-embed-large embeddings), rag/query_engine.py.
# Run locally: ollama serve  |  docker-compose spins up wealthos-ollama on this port.
OLLAMA_URL=http://localhost:11434

# Anthropic API key — used for PDF and image understanding only.
# Used by: input/pdf_processor.py (financial PDF parsing), input/vision_handler.py.
# Optional — only needed if you use the PDF/image input features.
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used for Whisper speech-to-text only.
# Used by: input/whisper_handler.py (voice query transcription).
# Optional — only needed if you use the voice input feature.
# Get key: https://platform.openai.com
OPENAI_API_KEY=sk-...

# ── Memory ────────────────────────────────────────────────────────────────────

# [REQUIRED for cross-session memory] Mem0 cloud API key.
# Used by: memory/mem0_client.py — reads user financial memory at pipeline start,
#          writes updated memory at pipeline end (writer_node in graph/nodes.py).
# Get key: https://app.mem0.ai
MEM0_API_KEY=m0-...

# ── MCP Servers / External Data APIs ─────────────────────────────────────────

# Base URL for the WealthOS finance MCP server (finance_server.py).
# Used by: agents/finance_agent.py to fetch personal finance data.
# Change if running MCP servers on a different host/port.
FINANCE_MCP_URL=http://localhost:8001

# NewsAPI.org key — used for financial news headlines and sentiment.
# Used by: mcp_servers/news_server.py (search_news, get_headlines, get_sentiment),
#          agents/research_agent.py.
# Get key: https://newsapi.org  (free tier: 100 req/day)
NEWSAPI_KEY=...

# Firecrawl API key — used for Reddit sentiment scraping (r/investing, r/stocks).
# Used by: mcp_servers/news_server.py (get_reddit_sentiment tool only).
# Optional — the tool returns a graceful warning if this is absent.
# Get key: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# SEC EDGAR User-Agent string — required by SEC to identify your application.
# Used by: mcp_servers/sec_edgar_server.py, rag/pipeline.py.
# Format: "AppName contact@email.com" — use your real email or SEC may rate-limit you.
SEC_USER_AGENT=WealthOS research@wealthos.app

# [REQUIRED for code sandbox] E2B cloud sandbox API key.
# Used by: agents/code_agent.py — runs DCF, Monte Carlo, sensitivity analysis
#          in an isolated Python sandbox. Pipeline degrades gracefully if absent.
# Get key: https://e2b.dev
E2B_API_KEY=e2b_...

# ── Observability ─────────────────────────────────────────────────────────────

# AgentOps API key — tracks agent sessions, MCP tool calls, and Mem0 operations.
# Used by: observability/agentops_config.py (init_agentops, track_node, track_memory_op).
# All tracking is silently disabled if absent.
# Get key: https://app.agentops.ai
AGENTOPS_API_KEY=...

# LangSmith API key — traces the full LangGraph pipeline waterfall.
# Used by: observability/langsmith_config.py (trace_node, trace_agent, verify_langsmith).
# All tracing is silently disabled if absent.
# Get key: https://smith.langchain.com
LANGCHAIN_API_KEY=ls__...

# Enable LangSmith tracing (must be "true" for traces to be captured).
# Used by: the LangSmith SDK reads this env var directly.
LANGCHAIN_TRACING_V2=true

# LangSmith project name — organises traces in the UI.
# Used by: observability/langsmith_config.py
LANGCHAIN_PROJECT=WealthOS

# Weights & Biases API key — used for eval result logging via W&B Weave.
# Used by: observability/weave_config.py (log_eval_result), eval/evaluate.py.
# All W&B logging is silently disabled if absent.
# Get key: https://wandb.ai
WANDB_API_KEY=...

# ── External APIs / Notifications ─────────────────────────────────────────────

# Composio API key — enables Gmail and WhatsApp notifications.
# Used by: services/composio_client.py (send_gmail, send_whatsapp, send_notification).
# Required for morning briefing emails and portfolio alerts.
# Get key: https://app.composio.dev
COMPOSIO_API_KEY=...

# Default email address for notifications (fallback if user DB record has no email).
# Used by: services/composio_client.py
NOTIFY_EMAIL=your@email.com

# Default WhatsApp phone number for notifications (E.164 format, e.g. +919876543210).
# Used by: services/composio_client.py
NOTIFY_PHONE=+919876543210

# ── Temporal ──────────────────────────────────────────────────────────────────

# Temporal server address for durable workflows (morning briefing cron).
# Used by: api/main.py (/briefing/send-now), workflows/morning_briefing.py,
#          workflows/temporal_worker.py.
# Note: currently hardcoded as "localhost:7233" in those files — a future refactor
# should read from this env var. docker-compose runs Temporal on the default port.
TEMPORAL_HOST=localhost:7233

# ── RAG / Vector Store ────────────────────────────────────────────────────────

# [REQUIRED for RAG] Qdrant Cloud cluster URL.
# Used by: rag/indexer.py, rag/query_engine.py — hybrid dense+sparse search.
# Get a free 1 GB cluster at https://cloud.qdrant.io (no credit card needed).
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io:6333

# [REQUIRED for RAG] Qdrant Cloud API key for the cluster above.
# Found in the Qdrant Cloud dashboard → cluster → API Keys.
QDRANT_API_KEY=...

# [REQUIRED for RAG] Voyage AI API key — used for voyage-finance-2 embeddings.
# Used by: rag/indexer.py (document indexing), rag/query_engine.py (query embedding).
# Free tier: 200 M tokens. Get key at https://dash.voyageai.com
VOYAGE_API_KEY=pa-...

# [REQUIRED for RAG reranking] Cohere API key — rerank-english-v3.0.
# Used by: rag/query_engine.py — re-orders top-20 hybrid hits to top-5.
# Free trial available at https://dashboard.cohere.com
COHERE_API_KEY=...

# ── Application ───────────────────────────────────────────────────────────────

# CORS allowed origins for the FastAPI backend, comma-separated.
# Used by: api/main.py (CORSMiddleware).
# Add your production frontend URL here before deploying.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501
